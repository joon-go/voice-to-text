# ── Pylon ───────────────────────────────────────────────────────────────────
# Admin API token (only admins can create tokens). The backend posts on behalf
# of individual engineers by stamping each message with their Pylon user_id,
# so the first response is attributed to the live person, not this token.
PYLON_API_TOKEN=

# Slug of the custom field that holds the tier. Enterprise Elite lives HERE,
# not in tags — tag-based search misses these tickets.
PYLON_TIER_FIELD_SLUG=support_tier
PYLON_TIER_VALUE="Enterprise Elite,Enterprise Pinnacle"

# Slug of the custom field that holds priority. Only P0 issues enter the queue.
PYLON_PRIORITY_FIELD_SLUG=priority
PYLON_PRIORITY_VALUE=Urgent

# Pylon team ID to filter issues by (e.g. L1+L2 team).
PYLON_TEAM_ID=

# Comma-separated Pylon user IDs to exclude when deciding "needs first response"
# (your two known bots). A ticket needs a first response when it has no message
# with is_private=false AND from_customer=false AND author NOT IN these IDs.
PYLON_BOT_IDS=

# First-response SLA window in minutes.
SLA_MINUTES=15

# ── Anthropic (problem summary the engineer hears) ───────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── PagerDuty (ack the incident when the engineer responds) ──────────────────
# Optional for v1. A user/account API token that can update incidents.
PAGERDUTY_API_TOKEN=
PAGERDUTY_FROM_EMAIL=

# Events API v2 integration key — used by the Pylon webhook to create
# PagerDuty incidents with a deeplink to the First Response app.
# Create at: PagerDuty → Services → your service → Integrations → Events API V2
PAGERDUTY_ROUTING_KEY=

# ── Google Auth ─────────────────────────────────────────────────────────────
# OAuth 2.0 Client ID from Google Cloud Console.
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Type: Web application. Add your Vercel URL as an authorized JS origin.
#
# IMPORTANT: GOOGLE_CLIENT_ID and VITE_GOOGLE_CLIENT_ID must ALWAYS be set to
# the same value. The frontend uses VITE_GOOGLE_CLIENT_ID to initialize Google
# Identity Services (src/App.jsx), and the backend uses GOOGLE_CLIENT_ID to
# verify the token audience (api/auth.js). Mismatched values will cause sign-in
# to fail even though the button renders.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── App ──────────────────────────────────────────────────────────────────────
# Set true to run the UI against mock data with no backend/secrets.
VITE_USE_MOCK=true

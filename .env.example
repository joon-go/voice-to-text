# ── Pylon ───────────────────────────────────────────────────────────────────
# Admin API token (only admins can create tokens). The backend posts on behalf
# of individual engineers by stamping each message with their Pylon user_id,
# so the first response is attributed to the live person, not this token.
PYLON_API_TOKEN=

# Slug of the custom field that holds the tier. Enterprise Elite lives HERE,
# not in tags — tag-based search misses these tickets.
PYLON_TIER_FIELD_SLUG=support_tier
PYLON_TIER_VALUE=Enterprise Elite

# Comma-separated Pylon user IDs to exclude when deciding "needs first response"
# (your two known bots). A ticket needs a first response when it has no message
# with is_private=false AND from_customer=false AND author NOT IN these IDs.
PYLON_BOT_IDS=

# First-response SLA window in minutes.
SLA_MINUTES=15

# ── Anthropic (problem summary the engineer hears) ───────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── PagerDuty (ack the incident when the engineer responds) ──────────────────
# Optional for v1. A user/account API token that can update incidents.
PAGERDUTY_API_TOKEN=
PAGERDUTY_FROM_EMAIL=

# ── App ──────────────────────────────────────────────────────────────────────
# Set true to run the UI against mock data with no backend/secrets.
VITE_USE_MOCK=true
